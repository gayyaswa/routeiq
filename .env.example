# RouteIQ — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Nebius AI Studio (active default) ────────────────────────────────────────
# Sign up at https://studio.nebius.ai — credits available on new accounts.
LLM_PROVIDER=nebius
LLM_MODEL=openai/gpt-oss-120b-fast
NEBIUS_API_KEY=v1....
NEBIUS_API_BASE=https://api.tokenfactory.nebius.com/v1/

# ── Anthropic (swap to this block to use Claude) ──────────────────────────────
#LLM_PROVIDER=anthropic
#LLM_MODEL=claude-sonnet-4-6
#ANTHROPIC_API_KEY=sk-ant-...

# ── Rating providers (POI quality signals) ───────────────────────────────────
# llm_synthetic  — always works; generates contextual ratings from Wikipedia descriptions
# tripadvisor    — real ratings + photos + reviews (flip here once key is active)
# foursquare     — secondary swappable provider
RATING_PROVIDER=llm_synthetic

# TripAdvisor — email developer-support@tripadvisor.com if you get 403 (account-level IAM deny).
# Once active, set RATING_PROVIDER=tripadvisor — no other code changes needed.
TRIPADVISOR_API_KEY=

# Foursquare v2 adapter (set RATING_PROVIDER=foursquare to activate)
FOURSQUARE_API_KEY=
FOURSQUARE_CLIENT_ID=
FOURSQUARE_CLIENT_SECRET=

# ── LangSmith tracing ─────────────────────────────────────────────────────────
# Free tier: 5,000 traces/month. Get key at smith.langchain.com → Settings → API Keys.
# Set LANGCHAIN_TRACING_V2=true to enable; comment out or remove to disable.
#LANGCHAIN_TRACING_V2=true
#LANGCHAIN_API_KEY=lsv2_pt_...
#LANGCHAIN_PROJECT=routeiq-week3
#LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
