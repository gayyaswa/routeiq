# RouteIQ — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "anthropic" (default) or "nebius"
LLM_PROVIDER=anthropic

# Model name — defaults to claude-sonnet-4-6 for anthropic if omitted
LLM_MODEL=claude-sonnet-4-6

# ── Anthropic (LLM_PROVIDER=anthropic) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Nebius AI Studio (LLM_PROVIDER=nebius) ───────────────────────────────────
# Sign up at https://studio.nebius.ai — credits available on new accounts.
# Check your studio dashboard for available model names.
#
# NEBIUS_API_KEY=eyJh...
# LLM_MODEL=<model-id-from-nebius-dashboard>
# NEBIUS_API_BASE=https://api.tokenfactory.nebius.com/v1/   # default, can omit
