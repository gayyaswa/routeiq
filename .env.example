# RouteIQ — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.
#
# MINIMUM SETUP: one LLM key is all you need to run the app.
# Everything else defaults to free/zero-key providers.

# ── LLM (required — pick one block) ──────────────────────────────────────────

# Option A — Anthropic (default, simplest)
# Get key at console.anthropic.com → API Keys
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...

# Option B — Nebius AI Studio (OpenAI-compatible, free credits on sign-up)
# Sign up at studio.nebius.ai, then uncomment and comment out Option A above.
#LLM_PROVIDER=nebius
#LLM_MODEL=openai/gpt-oss-120b-fast
#NEBIUS_API_KEY=v1....
#NEBIUS_API_BASE=https://api.tokenfactory.nebius.com/v1/

# ── Rating provider (optional upgrade) ───────────────────────────────────────
# RATING_PROVIDER: llm_synthetic (default, no key) | tripadvisor
# llm_synthetic — generates ratings from Wikipedia text; zero credentials needed
# tripadvisor   — real ratings + photos + reviews; email developer-support@tripadvisor.com if you get 403
RATING_PROVIDER=llm_synthetic

# Uncomment and fill in only if switching away from llm_synthetic:
#TRIPADVISOR_API_KEY=

# ── Activity provider (optional upgrade) ──────────────────────────────────────
# ACTIVITY_PROVIDER: osm (default, no key) | tavily
# osm    — free baseline using OpenStreetMap data; zero credentials needed
# tavily — richer activity search; free tier 1000 req/month (tavily.com)
ACTIVITY_PROVIDER=osm

# Uncomment and fill in only if switching away from osm:
#TAVILY_API_KEY=tvly-...

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
# Free tier: 5,000 traces/month. Get key at smith.langchain.com → Settings → API Keys.
#LANGCHAIN_TRACING_V2=true
#LANGCHAIN_API_KEY=lsv2_pt_...
#LANGCHAIN_PROJECT=routeiq
#LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
