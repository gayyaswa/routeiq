# RouteIQ — environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Anthropic (default) ───────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...

# ── Nebius AI Studio (swap to this block to use Nebius) ──────────────────────
# Sign up at https://studio.nebius.ai — credits available on new accounts.
#
#LLM_PROVIDER=nebius
#LLM_MODEL=openai/gpt-oss-120b-fast
#NEBIUS_API_KEY=v1....
#NEBIUS_API_BASE=https://api.tokenfactory.nebius.com/v1/

# ── Foursquare Places (POI ratings) ──────────────────────────────────────────
FOURSQUARE_API_KEY=
RATING_PROVIDER=foursquare